# Copy this file to api/.env and fill in your Supabase Postgres connection string.
#
# Recommended for local development:
# - Use Supabase's connection pooler URI if your network has trouble with direct IPv6.
# - Keep sslmode=require.
# - URL-encode special characters in the password.
#
# Supabase usually provides this standard PostgreSQL format.
# The app automatically converts postgresql:// to SQLAlchemy's psycopg driver internally.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Explicit SQLAlchemy + psycopg format also works:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Direct connection format also works when available:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

CORS_ORIGINS=http://localhost:3000
